# ==========================================
# Project Specific .gitignore (Next.js + Node.js Backend)
# ==========================================

# ------------------------------------------
# Dependencies
# ------------------------------------------
# Main frontend node modules
node_modules/
# Backend specifically-scoped node modules
backend/node_modules/

# ------------------------------------------
# Framework & Build Outputs (Next.js)
# ------------------------------------------
.next/
out/
build/
# Next.js typescript trace/definition caches
.tsbuildinfo
next-env.d.ts

# ------------------------------------------
# Environment Variables & Secrets
# ------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Generic secrets
*.env
*.pem

# ------------------------------------------
# Logs, Cache & Temp Files
# ------------------------------------------
# NPM / Package Manager debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
# Generic logs
logs/
*.log
# Testing coverage
coverage/

# ------------------------------------------
# Operating System Files
# ------------------------------------------
# Windows 
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
# macOS
.DS_Store
.AppleDouble
.LSOverride

# ------------------------------------------
# IDE & Editor Files
# ------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ------------------------------------------
# Legacy / Migration Folders
# ------------------------------------------
# Existing legacy directories in the project
/_legacy_vite/
/temp-next/

# ------------------------------------------
# Databases and Binaries
# ------------------------------------------
*.sqlite
*.sqlite3
*.db
*.iso
*.dmg
*.exe
*.dll
*.bin

# ------------------------------------------
# Large Media & Archives
# ------------------------------------------
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.mp3
*.wav
*.flac
*.psd
*.ai
*.sketch
*.zip
*.tar
*.tar.gz
*.rar
*.7z
